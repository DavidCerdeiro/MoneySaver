@startuml component-diagram
title Diagrama de Componentes
package "Frontend"{
    package "domains"{
        package "shared"{
            package "components-shared"{
                [set<ComponentsShared.tsx>]
            }
            package "layouts"{
                [set<Layouts.tsx>]
            }
            package "lib"{
                [utils.ts]
            }
        }
        package "domain"{
            package "application" {
                [set<DomainService.ts>]
            }
            package "components" {
                [set<DomainComponents.tsx>]
            }
            package "pages" {
                [set<DomainPages.tsx>]
            }
            package "schemas" {
                [set<Schemas.ts>]
            }
        }
        package "i18n"{
            package "locales"{
                [set<locales.json>]
            }
        }
        [main.tsx]
    }
}

package "Backend"{
    package "name-entity"{
        package "entity" {
            [Entity.java]
        }
        package "service" {
            [EntityService.java]
        }
        package "controller" {
            [EntityController.java]
        }
        package "repository" {
            [EntityRepository.java]
        }
        package "dto" {
            [set<Dtos.java>]
        }
    }
    package "test"{
        [BackendApplicationTests.java]
        package "unit_tests"{
            [set<EntityUnitTests.java>]
        }
    }
    package "resources"{
        package "messages"{
            [set<messages.properties>]
        }
    }
    [BackendApplication.java]
}
database "PostgreSQL"

'------
' Relationships - Frontend
'------
[main.tsx] --> [set<DomainPages.tsx>]
[set<DomainPages.tsx>] --> [set<DomainComponents.tsx>]
[set<DomainPages.tsx>] --> [set<DomainService.ts>]
[set<DomainComponents.tsx>] --> [set<ComponentsShared.tsx>]
[set<DomainComponents.tsx>] --> [set<Layouts.tsx>]
[set<ComponentsShared.tsx>] --> [utils.ts]
[set<DomainComponents.tsx>] --> [set<Schemas.ts>]
[set<DomainComponents.tsx>] --> [set<locales.json>]
[set<Layouts.tsx>] --> [set<locales.json>]
'------
' Relationships - Backend
'------

[EntityController.java] --> [EntityService.java]
[EntityService.java] --> [EntityRepository.java]
[EntityController.java] --> [set<Dtos.java>]
[EntityService.java] --> [Entity.java]
[EntityService.java] --> [set<messages.properties>]
[EntityRepository.java] --> [Entity.java]
[EntityRepository.java] --> [PostgreSQL]
[BackendApplicationTests.java] --> [set<EntityUnitTests.java>]

'------
' Relationships - Backend - Frontend
'------
[EntityController.java] --> [set<DomainService.ts>]
[set<DomainService.ts>] --> [EntityController.java]
@enduml